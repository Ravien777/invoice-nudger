generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String             @unique
  emailVerified    DateTime?
  image            String?
  plan             String             @default("free")
  stripeCustomerId String?
  stripeSubscriptionId String?
  stripePriceId    String?
  subscriptionStatus String?
  aiTone           String             @default("professional")
  aiRemindersEnabled Boolean          @default(false)
  portalBranding    String?
  portalEnabled     Boolean          @default(false)
  lateFeeEnabled    Boolean          @default(false)
  lateFeeType       String           @default("fixed")
  lateFeeValue      Float            @default(0)
  lateFeeFrequency  String           @default("once")
  interestEnabled   Boolean          @default(false)
  interestRate      Float            @default(0)
  lateFeeGraceDays  Int              @default(0)
  feeCap            Float            @default(0)
  taxRate           Float            @default(0.25)
  fiscalYearStart   Int              @default(1)
  taxSavingsAmount  Float            @default(0)
  baseCurrency      String     @default("USD")
  businessProfile   BusinessProfile?
  lastPayYourselfDate DateTime?
  alertPreferences  Json?
  allocationProfile    AllocationProfile?
  allocationRecords    AllocationRecord[]
  accounts         Account[]
  sessions         Session[]
  invoices         Invoice[]
  reminderSchedules ReminderSchedule[]
  integrations     IntegrationConnection[]
  syncLogs         SyncLog[]
  aiUsage          AIReminderUsage[]
  notificationUsage NotificationUsage[]
  portalTokens     ClientPortalToken[]
  industry         String?
  benchmarksOptOut Boolean          @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  dailySummaries   InvoiceDailySummary[]
  clientProfiles   ClientPaymentProfile[]
  notifications    Notification[]
  expenses         Expense[]
  expenseCategories ExpenseCategory[]
  quotes           Quote[]
  recurringInvoices RecurringInvoice[]
  accountantAccess  AccountantAccess[] @relation("OwnerAccess")
}

model BusinessProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxRate           Float   @default(0.25)
  fiscalYearStart   Int     @default(1)
  taxSavingsAmount  Float   @default(0)
  baseCurrency      String  @default("USD")
  defaultHourlyRate Float?
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invoice {
  id                   String   @id @default(cuid())
  invoiceNumber        String?
  clientName           String
  clientEmail          String
  clientPhone          String?
  projectName          String?
  amount               Float
  currency             String   @default("USD")
  dueDate              DateTime
  status               String   @default("unpaid")
  notes                String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  reminderScheduleId   String?
  reminderSchedule     ReminderSchedule? @relation(fields: [reminderScheduleId], references: [id])
  reminders            ReminderLog[]
  source               String?
  externalId           String?
  externalContactId    String?
  lastSyncedAt         DateTime?
  paymentLink          String?
  paidAt               DateTime?
  reconciliationStatus String?
  lastReconciledAt     DateTime?
  payments             PaymentRecord[]
  promiseEvents        PromiseEvent[]
  promisedDate         DateTime?
  promiseDetectedAt    DateTime?
  promiseStatus        String   @default("none")
  promiseConfidence    Float?
  paymentProbability   Float?
  lateFeeEnabled       Boolean          @default(false)
  lateFeeAmount        Float            @default(0)
  interestRate         Float            @default(0)
  accruedFees          Float            @default(0)
  lastFeeCalculation   DateTime?
  feeCap               Float            @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ReminderSchedule {
  id            String         @id @default(cuid())
  name          String
  isDefault     Boolean        @default(false)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  steps         ReminderStep[]
  invoices      Invoice[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ReminderStep {
  id                 String           @id @default(cuid())
  daysOffset         Int
  emailTemplate      String
  reminderScheduleId String
  schedule           ReminderSchedule @relation(fields: [reminderScheduleId], references: [id])
}

model ReminderLog {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  sentAt        DateTime @default(now())
  stepName      String
  channel       String   @default("email")
  sentTo        String?
  emailBody     String?
  subjectLine   String?
  approved      Boolean  @default(false)
  aiGenerated   Boolean  @default(false)
  messageId     String?
  errorMessage  String?
  promiseEventId String?
}

model IntegrationConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  tenantId     String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, platform])
}

model SyncLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform      String
  direction     String
  status        String
  recordsSynced Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
}

model AIReminderUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     Int
  year      Int
  count     Int      @default(0)

  @@unique([userId, month, year])
}

model ClientPortalToken {
  id             String   @id @default(cuid())
  token          String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEmail    String
  clientName     String?
  isActive       Boolean  @default(true)
  expiresAt      DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime @default(now())

  @@index([userId, clientEmail])
}

model PaymentRecord {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  source        String
  amount        Float
  currency      String
  paidAt        DateTime
  referenceId   String?
  status        String   @default("unreconciled")
  notes         String?
  createdAt     DateTime @default(now())

  @@index([invoiceId])
  @@index([source])
}

model NotificationUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String
  month     Int
  year      Int
  count     Int      @default(0)

  @@unique([userId, channel, month, year])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model SMSOptOut {
  id         String   @id @default(cuid())
  phone      String
  channel    String
  optedOutAt DateTime @default(now())

  @@unique([phone, channel])
}

model PromiseEvent {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  detectedAt      DateTime @default(now())
  promisedDate    DateTime
  emailSubject    String?
  emailSnippet    String?
  confidence      Float
  status          String   @default("active")
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceId])
  @@index([status])
}

model InvoiceDailySummary {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date
  totalInvoices     Int @default(0)
  paidInvoices      Int @default(0)
  overdueInvoices   Int @default(0)
  totalAmount       Float @default(0)
  collectedAmount   Float @default(0)
  overdueAmount     Float @default(0)
  avgDaysToPay      Float?
  activeClientEmails Json?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model ClientPaymentProfile {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  clientEmail     String
  totalInvoices   Int      @default(0)
  paidInvoices    Int      @default(0)
  onTimePayments  Int      @default(0)
  totalAmount     Float    @default(0)
  avgDaysLate     Float?
  lastPaymentDate DateTime?
  riskScore       Float?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([userId, clientEmail])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  isDefault Boolean   @default(false)
  expenses  Expense[]
  createdAt DateTime  @default(now())

  @@unique([userId, name])
}

model Expense {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  description   String
  amount        Float
  currency      String           @default("USD")
  date          DateTime         @db.Date
  vendor        String?
  receiptUrl    String?
  taxDeductible Boolean          @default(true)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Quote {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteNumber    String?
  clientName     String
  clientEmail    String
  clientAddress  String?
  issueDate      DateTime        @default(now())
  expiryDate     DateTime?
  status         String          @default("draft") // draft | sent | accepted | declined | expired
  amount         Float
  subtotal       Float?
  totalTax       Float?
  currency       String          @default("USD")
  notes          String?
  sellerName     String?
  sellerAddress  String?
  sellerTaxId    String?
  paymentTerms   String?
  convertedToInvoiceId String?   @unique
  lineItems      QuoteLineItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  taxRate     Float?
  taxAmount   Float?
  total       Float
  sortOrder   Int     @default(0)
}

model RecurringInvoice {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientName      String
  clientEmail     String
  clientPhone     String?
  amount          Float
  currency        String    @default("USD")
  frequency       String    // "weekly" | "biweekly" | "monthly" | "quarterly" | "annually"
  dayOfMonth      Int?      // 1–28, for monthly/quarterly/annually
  nextRunDate     DateTime
  endDate         DateTime?
  description     String?
  status          String    @default("active") // "active" | "paused" | "cancelled"
  autoSend        Boolean   @default(true)
  invoicesCreated Int       @default(0)
  lastRunDate     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model IndustryBenchmark {
  id             String   @id @default(cuid())
  industry       String
  metric         String
  value          Float
  sampleSize     Int
  computedAt     DateTime @default(now())

  @@unique([industry, metric, computedAt])
}

model AccountantAccess {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation("OwnerAccess", fields: [ownerId], references: [id], onDelete: Cascade)
  accountantEmail String
  accountantUserId String?
  status          String   @default("pending") // pending | active | revoked
  inviteToken     String   @unique @default(cuid())
  invitedAt       DateTime @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?

  @@unique([ownerId, accountantEmail])
}

model AllocationProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxPercent      Float    @default(25)
  operatingPercent Float   @default(30)
  profitPercent   Float    @default(5)
  ownerPayPercent Float    @default(40)
  currency        String   @default("USD")
  updatedAt       DateTime @updatedAt
}

model AllocationRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceId       String?
  totalReceived   Float
  taxAmount       Float
  operatingAmount Float
  profitAmount    Float
  ownerPayAmount  Float
  currency        String   @default("USD")
  note            String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}
