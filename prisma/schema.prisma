generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String             @unique
  emailVerified    DateTime?
  password         String?
  image            String?
  plan             String             @default("free")
  stripeCustomerId String?
  stripeSubscriptionId String?
  stripePriceId    String?
  subscriptionStatus String?
  aiTone           String             @default("professional")
  aiRemindersEnabled Boolean          @default(false)
  portalBranding    String?
  portalEnabled     Boolean          @default(false)
  lateFeeEnabled    Boolean          @default(false)
  lateFeeType       String           @default("fixed")
  lateFeeValue      Float            @default(0)
  lateFeeFrequency  String           @default("once")
  interestEnabled   Boolean          @default(false)
  interestRate      Float            @default(0)
  lateFeeGraceDays  Int              @default(0)
  feeCap            Float            @default(0)
  receiptEmail       String?    @unique
  businessProfile   BusinessProfile?
  alertPreferences  Json?
  allocationProfile    AllocationProfile?
  allocationRecords    AllocationRecord[]
  contracts            Contract[]
  contractTemplates    ContractTemplate[]
  accounts         Account[]
  sessions         Session[]
  invoices         Invoice[]
  reminderSchedules ReminderSchedule[]
  integrations     IntegrationConnection[]
  syncLogs         SyncLog[]
  aiUsage          AIReminderUsage[]
  notificationUsage NotificationUsage[]
  portalTokens     ClientPortalToken[]
  industry         String?
  benchmarksOptOut Boolean          @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  dailySummaries   InvoiceDailySummary[]
  clientProfiles   ClientPaymentProfile[]
  notifications    Notification[]
  expenses         Expense[]
  expenseCategories ExpenseCategory[]
  timeEntries      TimeEntry[]
  contractors      Contractor[]
  contractorPayments ContractorPayment[]
  quotes           Quote[]
  recurringInvoices RecurringInvoice[]
  bankConnections   BankConnection[]
  bankTransactions  BankTransaction[]
  accountantAccess  AccountantAccess[] @relation("OwnerAccess")
  teamMembers       TeamMember[] @relation("TeamOwner")
}

model BusinessProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxRate           Float   @default(0.25)
  fiscalYearStart   Int     @default(1)
  taxSavingsAmount  Float   @default(0)
  baseCurrency      String  @default("USD")
  lastPayYourselfDate DateTime?
  defaultHourlyRate Float?
  businessName      String?
  businessAddress   String?
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invoice {
  id                   String   @id @default(cuid())
  invoiceNumber        String?
  clientName           String
  clientEmail          String
  clientPhone          String?
  projectName          String?
  amount               Float
  currency             String   @default("USD")
  dueDate              DateTime
  status               String   @default("unpaid")
  notes                String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  reminderScheduleId   String?
  reminderSchedule     ReminderSchedule? @relation(fields: [reminderScheduleId], references: [id])
  reminders            ReminderLog[]
  source               String?
  externalId           String?
  externalContactId    String?
  lastSyncedAt         DateTime?
  paymentLink          String?
  paidAt               DateTime?
  instantPayoutId      String?
  paidOutAt            DateTime?
  reconciliationStatus String?
  lastReconciledAt     DateTime?
  payments             PaymentRecord[]
  promiseEvents        PromiseEvent[]
  promisedDate         DateTime?
  promiseDetectedAt    DateTime?
  promiseStatus        String   @default("none")
  promiseConfidence    Float?
  paymentProbability   Float?
  lateFeeEnabled       Boolean          @default(false)
  lateFeeAmount        Float            @default(0)
  interestRate         Float            @default(0)
  accruedFees          Float            @default(0)
  lastFeeCalculation   DateTime?
  feeCap               Float            @default(0)
  lineItems            InvoiceLineItem[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId, status, paidAt])
  @@index([userId, status, createdAt])
  @@index([userId, createdAt])
  @@index([userId, reconciliationStatus])
  @@index([userId, clientEmail])
  autoCharge              Boolean   @default(false)
  autoChargeRetryCount    Int       @default(0)
  autoChargeLastError     String?
  autoChargeLastAttemptAt DateTime?
  stripePaymentIntentId   String?
  paymentPlan             PaymentPlan?
  @@index([lateFeeEnabled, status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float?
  taxAmount   Float?
  total       Float
  sortOrder   Int
}

model ReminderSchedule {
  id            String         @id @default(cuid())
  name          String
  isDefault     Boolean        @default(false)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  steps             ReminderStep[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ReminderStep {
  id                 String           @id @default(cuid())
  daysOffset         Int
  emailTemplate      String
  reminderScheduleId String
  schedule           ReminderSchedule @relation(fields: [reminderScheduleId], references: [id])
}

model ReminderLog {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  sentAt        DateTime @default(now())
  stepName      String
  channel       String   @default("email")
  sentTo        String?
  emailBody     String?
  subjectLine   String?
  approved      Boolean  @default(false)
  aiGenerated   Boolean  @default(false)
  messageId     String?
  errorMessage  String?
  promiseEventId String?
}

model IntegrationConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  tenantId     String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, platform])
}

model SyncLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform      String
  direction     String
  status        String
  recordsSynced Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
}

model AIReminderUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     Int
  year      Int
  count     Int      @default(0)

  @@unique([userId, month, year])
}

model ClientPortalToken {
  id             String   @id @default(cuid())
  token          String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEmail    String
  clientName     String?
  isActive       Boolean  @default(true)
  expiresAt      DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime @default(now())

  @@index([userId, clientEmail])
}

model PaymentRecord {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  source        String
  amount        Float
  currency      String
  paidAt        DateTime
  referenceId   String?
  status        String   @default("unreconciled")
  notes         String?
  createdAt     DateTime @default(now())

  @@index([invoiceId])
  @@index([source])
}

model NotificationUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String
  month     Int
  year      Int
  count     Int      @default(0)

  @@unique([userId, channel, month, year])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model SMSOptOut {
  id         String   @id @default(cuid())
  phone      String
  channel    String
  optedOutAt DateTime @default(now())

  @@unique([phone, channel])
}

model PromiseEvent {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  detectedAt      DateTime @default(now())
  promisedDate    DateTime
  emailSubject    String?
  emailSnippet    String?
  confidence      Float
  status          String   @default("active")
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceId])
  @@index([status])
  @@index([invoiceId, status])
}

model InvoiceDailySummary {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date
  totalInvoices     Int @default(0)
  paidInvoices      Int @default(0)
  overdueInvoices   Int @default(0)
  totalAmount       Float @default(0)
  collectedAmount   Float @default(0)
  overdueAmount     Float @default(0)
  avgDaysToPay      Float?
  activeClientEmails Json?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model ClientPaymentProfile {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  clientEmail     String
  totalInvoices   Int      @default(0)
  paidInvoices    Int      @default(0)
  onTimePayments  Int      @default(0)
  totalAmount     Float    @default(0)
  avgDaysLate     Float?
  lastPaymentDate DateTime?
  riskScore       Float?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([userId, clientEmail])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  isDefault Boolean   @default(false)
  expenses  Expense[]
  createdAt DateTime  @default(now())

  @@unique([userId, name])
}

model Expense {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  description   String
  amount        Float
  currency      String           @default("USD")
  date          DateTime         @db.Date
  vendor        String?
  receiptUrl    String?
  taxDeductible Boolean          @default(true)
  notes         String?
  status        String           @default("confirmed") // confirmed | draft
  clientEmail   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId, date])
  @@index([userId, status, date])
  @@index([clientEmail])
}

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEmail     String
  clientName      String?
  description     String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  hourlyRate      Float?
  currency        String    @default("USD")
  invoiced        Boolean   @default(false)
  invoiceId       String?
  createdAt       DateTime  @default(now())

  @@index([userId, startTime])
}

model BankConnection {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String            @default("plaid")
  accessToken     String
  itemId          String?
  institutionName String?
  accountName     String?
  accountMask     String?
  status          String            @default("active")
  lastSyncAt      DateTime?
  createdAt       DateTime          @default(now())
  transactions    BankTransaction[]
}

model BankTransaction {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       BankConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  externalId       String          @unique
  date             DateTime        @db.Date
  description      String
  amount           Float
  currency         String          @default("USD")
  category         String?
  matchedInvoiceId String?
  matchedExpenseId String?
  status           String          @default("unmatched")
  createdAt        DateTime        @default(now())

  @@index([userId, status])
  @@index([userId, date])
}

model Quote {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteNumber    String?
  clientName     String
  clientEmail    String
  clientAddress  String?
  issueDate      DateTime        @default(now())
  expiryDate     DateTime?
  status         String          @default("draft") // draft | sent | accepted | declined | expired
  amount         Float
  subtotal       Float?
  totalTax       Float?
  currency       String          @default("USD")
  notes          String?
  sellerName     String?
  sellerAddress  String?
  sellerTaxId    String?
  paymentTerms   String?
  convertedToInvoiceId String?   @unique
  lineItems      QuoteLineItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  taxRate     Float?
  taxAmount   Float?
  total       Float
  sortOrder   Int     @default(0)
}

model RecurringInvoice {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientName         String
  clientEmail        String
  clientPhone        String?
  amount             Float
  currency           String              @default("USD")
  frequency          String              // "weekly" | "biweekly" | "monthly" | "quarterly" | "annually"
  dayOfMonth         Int?                // 1–28, for monthly/quarterly/annually
  nextRunDate        DateTime
  endDate            DateTime?
  description        String?
  lineItems          Json?
  status             String              @default("active") // "active" | "paused" | "cancelled"
  autoSend           Boolean             @default(true)
  reminderScheduleId String?
  reminderSchedule   ReminderSchedule?   @relation(fields: [reminderScheduleId], references: [id])
  invoicesCreated    Int                 @default(0)
  lastRunDate        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId])
  @@index([status, nextRunDate])
}

model IndustryBenchmark {
  id             String   @id @default(cuid())
  industry       String
  metric         String
  value          Float
  sampleSize     Int
  computedAt     DateTime @default(now())

  @@unique([industry, metric, computedAt])
}

model PlazaosClient {
  id               String   @id @default(cuid())
  plazaosClientId  Int      @unique
  companyName      String
  contactName      String
  email            String
  phone            String?
  website          String?
  industry         String?
  city             String?
  country          String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([email])
}

model AccountantAccess {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation("OwnerAccess", fields: [ownerId], references: [id], onDelete: Cascade)
  accountantEmail String
  accountantUserId String?
  status          String   @default("pending") // pending | active | revoked
  inviteToken     String   @unique @default(cuid())
  invitedAt       DateTime @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?

  @@unique([ownerId, accountantEmail])
  @@index([accountantEmail, status])
}

model TeamMember {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberEmail  String
  memberUserId String?
  role         String    @default("member") // "member" | "viewer"
  status       String    @default("pending") // "pending" | "active" | "removed"
  inviteToken  String    @unique @default(cuid())
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime?
  removedAt    DateTime?

  @@unique([ownerId, memberEmail])
}

model Contractor {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String
  role      String?
  rate      Float?
  rateType  String?
  taxId     String?
  payments  ContractorPayment[]
  createdAt DateTime            @default(now())
}

model ContractorPayment {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractorId  String
  contractor    Contractor  @relation(fields: [contractorId], references: [id])
  amount        Float
  currency      String      @default("USD")
  description   String
  paymentDate   DateTime    @db.Date
  payslipUrl    String?
  expenseId     String?     @unique
  createdAt     DateTime    @default(now())
}

model AllocationProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxPercent      Float    @default(25)
  operatingPercent Float   @default(30)
  profitPercent   Float    @default(5)
  ownerPayPercent Float    @default(40)
  currency        String   @default("USD")
  updatedAt       DateTime @updatedAt
}

model AllocationRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceId       String?
  totalReceived   Float
  taxAmount       Float
  operatingAmount Float
  profitAmount    Float
  ownerPayAmount  Float
  currency        String   @default("USD")
  note            String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model ContractTemplate {
  id        String     @id @default(cuid())
  userId    String?    // null = system default template
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  body      String     @db.Text  // HTML with {{variables}}
  isDefault Boolean    @default(false)
  contracts Contract[]
  createdAt DateTime   @default(now())
}

model Contract {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId   String?
  template     ContractTemplate? @relation(fields: [templateId], references: [id])
  quoteId      String?           @unique
  invoiceId    String?
  clientName   String
  clientEmail  String
  title        String
  body         String            @db.Text   // final rendered content
  status       String            @default("draft") // draft | sent | signed | declined
  signingToken String            @unique @default(cuid())
  signedAt     DateTime?
  signedByName String?
  signedByIp   String?
  pdfUrl       String?
  sentAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ClientPaymentMethod {
  id                    String    @id @default(cuid())
  userId                String
  clientEmail           String
  clientName            String?
  stripeCustomerId      String
  stripePaymentMethodId String
  stripeSetupIntentId   String?
  isDefault             Boolean   @default(false)
  status                String    @default("active") // active | expired | removed
  lastChargedAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, clientEmail])
  @@index([stripeCustomerId])
}

model PaymentPlan {
  id           String   @id @default(cuid())
  invoiceId    String   @unique
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  totalAmount  Float
  currency     String   @default("USD")
  installments Int      @default(1)
  intervalDays Int      @default(30)
  status       String   @default("active") // active | completed | cancelled | paused
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  installmentsList PaymentPlanInstallment[]

  @@index([invoiceId])
  @@index([status])
}

model PaymentPlanInstallment {
  id              String    @id @default(cuid())
  planId          String
  plan            PaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  amount          Float
  dueDate         DateTime
  status          String    @default("pending") // pending | paid | failed | skipped
  stripePaymentIntentId String?
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  createdAt       DateTime  @default(now())

  @@index([planId])
  @@index([status, dueDate])
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  label       String
  keyPrefix   String
  keyHash     String   @unique
  scopes      String   @default("read") // read | write
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  status      String   @default("active") // active | revoked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
}

model WebhookEndpoint {
  id              String   @id @default(cuid())
  userId          String
  url             String
  secret          String
  events          String[] // ["invoice.paid", "client.created", ...]
  status          String   @default("active") // active | paused | disabled
  lastDeliveredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, status])
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  endpointId    String
  event         String
  payload       Json
  status        String   // success | failed
  responseCode  Int?
  responseBody  String?
  durationMs    Int?
  errorMessage  String?
  attemptNumber Int      @default(1)
  nextRetryAt   DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([endpointId, createdAt])
  @@index([nextRetryAt])
}

model ApiRateLimit {
  id        String   @id @default(cuid())
  keyId     String
  windowStart DateTime
  count     Int      @default(0)

  @@unique([keyId, windowStart])
  @@index([keyId, windowStart])
}
